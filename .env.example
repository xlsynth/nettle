# Source this file before starting the native viewer server.
NETTLE_ENABLE_AZURE_BUNDLES=false
NETTLE_AZURE_ROOTS=az://storage.example/container/project/
NETTLE_AZURE_TIMEOUT_SECONDS=600
NETTLE_AZURE_COMPILER_TIMEOUT_SECONDS=600
NETTLE_SLANG_BIN=/path/to/slang
NETTLE_YOSYS_BIN=/path/to/yosys
